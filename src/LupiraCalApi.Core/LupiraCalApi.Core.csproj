<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Keep the LupiraCalApi.* namespaces unchanged across the project split. -->
    <RootNamespace>LupiraCalApi</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- The bounded context + data: Domain (event-sourced aggregates + events + projections),
         Application (services + OpResult), Dtos, Mappers, Serialization, Auth/AccessResolver.
         Marten is the event store + document store on Postgres. No ASP.NET dependency — that lives in the host. -->
    <PackageReference Include="Marten" Version="9.6.0" />
    <PackageReference Include="Ical.Net" Version="5.2.2" />
    <PackageReference Include="FolkerKinzel.VCards" Version="8.1.3" />
  </ItemGroup>

</Project>
